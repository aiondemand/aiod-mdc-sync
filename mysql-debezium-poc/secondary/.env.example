# MySQL credentials must match the primary stack
MYSQL_ROOT_PASSWORD=changeit
MYSQL_DATABASE=test_db
MYSQL_USER=test_user
MYSQL_PASSWORD=test_pass

# Kafka bootstrap (must match PRIMARY_PUB_IP and listener port)
BOOTSTRAP_SERVERS=primary.example.com:9093

# Kafka client TLS configuration for the sink connector
CONNECT_SECURITY_PROTOCOL=SSL
CONNECT_SSL_TRUSTSTORE_LOCATION=/etc/kafka/secrets/kafka.client.truststore.p12
CONNECT_SSL_TRUSTSTORE_PASSWORD=changeit
CONNECT_SSL_TRUSTSTORE_TYPE=PKCS12
